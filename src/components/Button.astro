---
export interface Props {
  variant?: 'primary' | 'secondary'
  href?: string
  disabled?: boolean
}

const props = Astro.props
---

<a
  href={props.href ?? '#'}
  class={`button ${props.variant === 'secondary' ? 'button-secondary' : 'button-primary'} ${props.disabled ? 'button-disabled' : ''}`}
  role="button"
  tabindex={props.disabled ? -1 : 0}
  aria-disabled={props.disabled ? 'true' : 'false'}
>
  <slot />
</a>

<style>
  .button {
    display: inline-flex;
    padding: 16px 24px;
    justify-content: center;
    align-items: center;
    gap: 8px;
    border-radius: 40px;
    font-family: 'Victor Mono';
    font-size: 1.25rem;
    font-style: normal;
    font-weight: 400;
    line-height: 100%; /* 1.25rem */
    letter-spacing: -0.1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .button-primary {
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: var(--button-bg-gradient);
    box-shadow: var(--button-glow);
    color: var(--text-primary);
  }

  .button-primary:hover {
    background: var(--white);
    box-shadow: var(--button-glow-strong);
    color: var(--black);
  }

  .button-secondary {
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    background: var(--button-bg-secondary);
    box-shadow: var(--button-glow);
    color: var(--text-primary);
  }

  .button-secondary:hover {
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: var(--button-bg-gradient);
    box-shadow: var(--button-glow);
  }

  .button-disabled {
    cursor: not-allowed;
    opacity: 0.6;
    pointer-events: none;
  }
</style>

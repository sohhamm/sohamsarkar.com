---
import Layout from '../layouts/layout.astro'
import ProjectsSection from '../components/ProjectsSection.astro'

const content = {
  title: 'Projects | Soham Sarkar',
  description:
    'A selection of projects by Soham Sarkar — full-stack web apps and games built with React, SolidJS, TypeScript, Go, and Node.js. Source code on GitHub.',
}
---

<Layout content={content}>
  <main>
    <ProjectsSection />
  </main>

  <script>
    function initProjectsTagFilter() {
      const tags = document.querySelectorAll('.tag')
      const projects = document.querySelectorAll('.project-item') as NodeListOf<HTMLElement>

      tags.forEach(tag => {
        tag.addEventListener('click', () => {
          const selectedTag = tag.textContent
          projects.forEach(project => {
            const projectTags = project.querySelectorAll('.tag')
            const hasTag = Array.from(projectTags).some(t => t.textContent === selectedTag)
            project.style.display = hasTag ? 'flex' : 'none'
          })
        })
      })
    }

    initProjectsTagFilter()
    document.addEventListener('astro:page-load', initProjectsTagFilter)
  </script>
</Layout>
